# Copy to .env.local and fill in. Required for Dojo game creation (create game / create AI game on-chain).

# --- Dojo / Torii (required for creating games on-chain) ---
# Torii indexer URL for your Dojo world. Without this, the Dojo SDK does not init and createGame/createAiGame will fail.
# Run your own: torii --world <WORLD_ADDRESS> --http.cors_origins "*" (see tycoon_contract/README.md)
# Or use your deployed Torii URL for Tycoon Sepolia.
NEXT_PUBLIC_TORII_URL=https://your-torii-url.example.com

# Optional: relay URL if you use Dojo relay for auth/messages
# NEXT_PUBLIC_RELAY_URL=

# --- Starknet RPC (optional; defaults to Cartridge Sepolia) ---
# NEXT_PUBLIC_STARKNET_RPC_URL=https://api.cartridge.gg/x/starknet/sepolia

# --- Backend API (for guest games, leaderboard, etc.) ---
# Set this in production (e.g. Vercel) so "Save game" and create flows hit your backend.
# NEXT_PUBLIC_API_URL=http://localhost:3001/api

# --- EGS (Embeddable Game Standard) ---
# Optional. When set, the UI shows EGS Tracked / EGS Verified for on-chain games and polls the adapter for score.
# NEXT_PUBLIC_EGS_ADAPTER_ADDRESS=0x...

# --- Cartridge / hosting ---
# When embedded in Cartridge you may see 404s for arcade-mainnet/marketplace-mainnet Torii; those are from Cartridge's scripts, not this app. Set NEXT_PUBLIC_TORII_URL above so this app uses your Dojo Torii.
